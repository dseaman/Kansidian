{
	"name": "kansidian",
	"version": "0.2.1",
	"description": "Obsidian plugin: non-destructive Kanban view over SweetClaude backlog and milestones.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"sweetclaude",
		"kanban"
	],
	"license": "MIT",
	"author": "Dan Seaman",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dseaman/Kansidian.git"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.19.19",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
