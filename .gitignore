# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Obsidian vault config inside Kansidian's own .sweetclaude/ (only present if
# the maintainer dogfoods Kansidian against this repo). Workspace state shifts
# per Obsidian session and shouldn't be committed.
.sweetclaude/.obsidian/
